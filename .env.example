# Environment Variables for PiBot
# Copy this file to .env and fill in your values

# Telegram Bot Token
# Get this from BotFather on Telegram (@BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Database Configuration
# Path to SQLite database file (relative to project root)
DATABASE_FILE=usuarios.db

# Logging Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Optional: External API Keys or Services
# Add any other environment variables your bot needs here
